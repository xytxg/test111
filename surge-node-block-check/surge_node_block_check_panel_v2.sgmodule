#!name=节点阻断检测面板 V2
#!desc=在 Surge 策略组页面显示 Proxy 当前所选节点的可用性、出口 IP、延迟和阻断诊断。若旧版未显示，请安装此 V2。
#!system=ios

[Panel]
NodeBlockPanelV2 = title="节点阻断检测",content="模块已成功加载\n点击右侧刷新按钮检测 Proxy 当前节点",style=info,script-name=NodeBlockPanelScriptV2,update-interval=1

[Script]
NodeBlockPanelScriptV2 = type=generic,script-path=https://raw.githubusercontent.com/xytxg/test111/main/surge-node-block-check/surge_node_block_check.js?v=2,argument=Proxy,timeout=35,script-update-interval=3600
